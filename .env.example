# Copy this file to ".env" and fill in values. The real ".env" is gitignored.

# --- Cloudflare R2 (assembly job + manual uploads) ---
# Create an R2 API token: Cloudflare dashboard → R2 → Manage R2 API Tokens
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# Genre/category subfolder under music/, pre-processed/, and post-processed/ (e.g. korean)
ASSEMBLY_CATEGORY=korean

# Optional: override post-processed/ subfolder for assembly backgrounds (default: ASSEMBLY_CATEGORY)
# ASSEMBLY_IMAGES_FOLDER=korean

# YouTube channel slug — finished videos: music-video/{channel}/mv_*/
# Comma-separated list populates the dashboard dropdown (new channels can be typed in the UI).
ASSEMBLY_CHANNELS=

# youtube-uploader API — channel list + register finished videos on the per-channel upload queue
UPLOADER_API_URL=https://youtuber-uploader-app-17161979106.northamerica-northeast2.run.app
UPLOADER_API_KEY=

# Register each finished assembly on the uploader queue (default on; set false or use --no-queue-youtube to skip)
ASSEMBLY_QUEUE_YOUTUBE=true

# Optional: Cloud Run Job / docker run — text behind subject on thumbnail
THUMBNAIL_TEXT=PLAYLIST

# --- extend-backgrounds (Gemini image API) ---
# Create a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Optional: Gemini image extension ---
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_ASPECT_RATIO=16:9
GEMINI_IMAGE_SIZE=2K
GEMINI_OUTPUT_WIDTH=1600

# Optional: hosted control API (assembly-api)
ASSEMBLY_GCP_PROJECT=youtube-uploader-499603
ASSEMBLY_GCP_REGION=northamerica-northeast2
ASSEMBLY_JOB_NAME=music-assemble
EXTEND_JOB_NAME=music-extend
# Set false only to run Gemini extend in-process on this machine (not recommended).
# EXTEND_USE_GCP=false

# API auth — scripts, curl, automation (header: X-API-Key). Not needed in the browser after dashboard login.
ASSEMBLY_API_KEY=

# Dashboard auth — password unlocks / and sets a session cookie that also authorizes /v1/* from the browser.
ASSEMBLY_DASHBOARD_PASSWORD=

# Local dev only — GCP service account fields (one per JSON key; replaces *.json key file)
# Required for assembly-api to call Cloud Run Jobs locally:
ASSEMBLY_GCP_SA_TYPE=service_account
ASSEMBLY_GCP_SA_PROJECT_ID=
ASSEMBLY_GCP_SA_PRIVATE_KEY_ID=
ASSEMBLY_GCP_SA_PRIVATE_KEY=
ASSEMBLY_GCP_SA_CLIENT_EMAIL=
ASSEMBLY_GCP_SA_CLIENT_ID=
ASSEMBLY_GCP_SA_AUTH_URI=https://accounts.google.com/o/oauth2/auth
ASSEMBLY_GCP_SA_TOKEN_URI=https://oauth2.googleapis.com/token
ASSEMBLY_GCP_SA_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
ASSEMBLY_GCP_SA_CLIENT_X509_CERT_URL=
ASSEMBLY_GCP_SA_UNIVERSE_DOMAIN=googleapis.com

# Local dev only (Cloud Run uses 8080)
ASSEMBLY_API_HOST=127.0.0.1
ASSEMBLY_API_PORT=8080
# Set when running worker via API (written automatically by control plane; minutes)
# ASSEMBLY_EXECUTION_ID=asm_20260622_120000_a1b2c3d4
# ASSEMBLY_DURATION_MIN=90
# ASSEMBLY_VARIANCE_MIN=15

YOUTUBE_METADATA_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
GEMINI_TEXT_MODEL=gemini-2.5-flash
