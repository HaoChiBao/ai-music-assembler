# Copy this file to ".env" and fill in values. The real ".env" is gitignored.
#
# Used by: extend-backgrounds (Gemini image API) and add-text-behind-subject --segmenter gemini.

# --- Required for extend-backgrounds ---
# Create a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Optional ---
# Image model (example: Nano Banana Pro). Override with e.g. gemini-2.5-flash-image if you prefer Flash.
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Target aspect ratio for the generated frame (e.g. 16:9 for widescreen backgrounds).
GEMINI_ASPECT_RATIO=16:9

# API resolution bucket: 512, 1K, 2K, or 4K (see Gemini image generation docs). 2K + output width below ≈ sharp ~1600px-wide results.
GEMINI_IMAGE_SIZE=2K

# Resize saved PNG to this width (pixels), preserving aspect ratio. Default 1600. Set to 0 to keep native API size.
GEMINI_OUTPUT_WIDTH=1600

# --- Optional: upload-music-video / generate-music-videos (title + description) ---
# Provider for the YouTube title/description: auto (default), openai, or gemini.
# "auto" uses OpenAI when OPENAI_API_KEY is set below, otherwise Gemini.
YOUTUBE_METADATA_PROVIDER=auto
# If using OpenAI: create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Text models (defaults shown). Override to taste.
OPENAI_TEXT_MODEL=gpt-4o-mini
GEMINI_TEXT_MODEL=gemini-2.5-flash
# YouTube upload also needs a Google OAuth *client secret* JSON (Desktop app), not an env var:
#   download it from Google Cloud Console and place client_secret*.json in the project root
#   (auto-discovered), or pass --client-secret /path/to/file.json. The OAuth token is cached
#   to youtube_token.json on first run. Both files are gitignored.
